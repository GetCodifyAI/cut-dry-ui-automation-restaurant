<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >
<suite name="regression suit" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="com.cutanddry.qa.utils.RetryTransformer"/>
        <listener class-name="com.cutanddry.qa.utils.TestNGListener"/>
        <listener class-name="com.cutanddry.qa.utils.AIOSampleUIMethodListener"/>
    </listeners>
    <test name="operator tests">
        <parameter name="PART" value="Part Fourteen" />
        <classes>
            <class name="com.cutanddry.qa.tests.OrderGuide.VerifyTheRevenueSummeryIsDisplayedCorrectlyOnTheEditOrderFlowTest" />

            <class name="com.cutanddry.qa.tests.DP_Specific_Suppliers.VerifyMultipleShipToAddressDisplayAndSelectionTest" />
            <class name="com.cutanddry.qa.tests.DP_Specific_Suppliers.VerifySingleShipToAddressFallbackTest" />

            <class name="com.cutanddry.qa.tests.Catalog.VerifyThatTheItemTypeFilterIsVisibleForOtherDPsOperatorsTest" />
            <class name="com.cutanddry.qa.tests.Catalog.VerifyOperatorsDoesNotHaveSpecialItemsTest" />

            <class name="com.cutanddry.qa.tests.Catalog.VerifyThatTheGPOFilterOptionInTheCatalogAvailableForOtherOPsTest" />
            <class name="com.cutanddry.qa.tests.Catalog.VerifyThatOPsDisplayTheirOwnProductsAlongWithProductsFromOtherManufacturersTest" />
            <class name="com.cutanddry.qa.tests.Catalog.VerifyThatDistributionCentreFilterIsFilteringRelevantDistributorCentresForOPSideTest" />

            <class name="com.cutanddry.qa.tests.OrderGuide.VerifyThatTheOrderGuideNameAndDescriptionInOrderGuideSettingsTest" />
            <class name="com.cutanddry.qa.tests.OrderGuide.VerifyThatTheOrderGuideLocationInOrderGuideSettingsTest" />

            <class name="com.cutanddry.qa.tests.Orders.VerifyFindMoreInCatalogButtonTest" />
            <class name="com.cutanddry.qa.tests.Orders.VerifyThatTheOrderUponEditingWithInactiveItemsTest" />
            <class name="com.cutanddry.qa.tests.Orders.VerifyThatTheOrderUponRecreatingWithInactiveItemsTest" />

            <class name="com.cutanddry.qa.tests.DP_Specific_Suppliers.VerifyAddToOrderGuideIconOnItemsWillNotDisplayedForTheOperatorsWhenTheCatalogOnlyOrderFlowIsActivatedTest" />

            <class name="com.cutanddry.qa.tests.Orders.VerifyTheGlobalOrderMinimumAmountIsAppliedWhenUseGlobalSettingsIsConfiguredWithHardOrderMinimumTest" />
            <class name="com.cutanddry.qa.tests.Orders.VerifyTheGlobalOrderMinimumAmountIsAppliedWhenUseGlobalSettingsIsConfiguredWithSoftOrderMinimumTest" />
            <class name="com.cutanddry.qa.tests.Orders.VerifyOrderMinimumIsNotAppliedWhenNoOrderMinimumIsConfiguredTest" />
        </classes>
    </test>
</suite>